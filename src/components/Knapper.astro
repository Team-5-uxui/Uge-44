---
const { text, variant } = Astro.props;
---

<button class={variant}>
  {text}
</button>

<style>
  .btn-sekundær {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 30px;
    margin-top: 2em;
    background-color: #3d2b1f;
    color: white;
    cursor: pointer;
  }

  .btn-sekundær:hover {
    background-color: #2c2520;
  }

.btn-primær {
    padding: 0.5rem 1rem;
    border: #2C2520 2px solid;
    border-radius: 30px;
    margin-top: 2em;
    background-color: #f3f3f3;
    color: #2c2520;
    cursor: pointer;
  }

  .btn-primær:hover {
    background-color: #D7D7D7;
  }

