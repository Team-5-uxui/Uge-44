---
const { eventnavn, img, about, place, text, buttonText, buttonVariant, id } = Astro.props;
import Knapper from "./Knapper.astro";

const options = {
  headers: {
    apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFic3VmbXdrbGFicW1hZHdjZ2pwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyOTE3NjIsImV4cCI6MjA5MTg2Nzc2Mn0.Mqg9pBJxpA-9JPfMoh_xioh3TdfMQgieL4Wbrtp83Ao",
  },
};

const url = "https://qbsufmwklabqmadwcgjp.supabase.co/rest/v1/events";

const response = await fetch(url, options);
const data = await response.json();
---

<dialog id={id} popover>
  <button class="luk-knap" popovertarget={id} popovertargetaction="hide">✕</button>

  <div class="grid_1-2">
    <img src={img} alt={eventnavn} />
    <div>
      <h2>{eventnavn}</h2>
      <p>{text}</p>
      <p>{place}</p>
    </div>
  </div>
  <div>
    <h3>Om eventet:</h3>
    <p>{about}</p>
  </div>
  <div class="btn">
    {buttonText && <Knapper text={buttonText} variant={buttonVariant} />}
  </div>
</dialog>

<style>
  .grid_1-2 {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2em;
  }

  .grid_1-2 div {
    margin-top: 4em;
  }

  dialog[popover] {
    max-width: 70%;
    background-color: var(--primary-section-bg);
    color: var(--text-color);
    padding: 2em;
    border-radius: 30px;
    border: none;
    max-height: 80vh;
    overflow-y: auto;

    transition:
      display 0.3s allow-discrete,
      overlay 0.3s allow-discrete,
      opacity 0.3s,
      transform 0.3s;

    opacity: 1;
    transform: translateY(0);
  }

  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.5);
  }

  dialog[popover]:not(:popover-open) {
    opacity: 0;
    transform: translateY(20px);
  }

  @starting-style {
    dialog[popover]:popover-open {
      opacity: 0;
      transform: translateY(20px);
    }
  }

  dialog[popover]::backdrop {
    transition:
      display 0.3s allow-discrete,
      overlay 0.3s allow-discrete,
      opacity 0.3s;
    opacity: 1;
  }

  @starting-style {
    dialog[popover]::backdrop {
      opacity: 0;
    }
  }

  .luk-knap {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-color);
    line-height: 1;
  }

  .luk-knap:hover {
    color: var(--heading-color);
  }

  @media (max-width: 800px) {
    .grid_1-2 {
      grid-template-columns: 1fr;
      gap: 1em;
    }

    .grid_1-2 div {
      margin-top: 0;
    }

    dialog[popover] {
      max-width: 90%;
    }

    .grid_1-2 img {
      margin: 0 auto;
    }
  }
</style>
