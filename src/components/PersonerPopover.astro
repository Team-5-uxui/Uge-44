---

<dialog id={id} popover>
  <button class="luk-knap" popovertarget={id} popovertargetaction="hide">✕</button>
  <div class="grid_1-2">
    <img src={img} alt={title} />
    <div>
      <h2>{title}</h2>
      <p>{age}</p>
      <p>{lost}</p>
    </div>
  </div>
  <div>
    <h3>Min historie</h3>
    <p>{story}</p>
    <h3>Mit bedste råd</h3>
    <p>{advice}</p>
  </div>
</dialog>

<style>
  .grid_1-2 {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }

  .grid_1-2 div {
    margin-top: 6em;
    padding-left: 2em;
  }

  dialog {
    margin-top: 5em;
    margin-bottom: 5em;
    max-width: 70%;
    background-color: var(--primary-section-bg);
    padding: 2em;
    border-radius: 30px;
    border: none;
  }

  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.5);
  }

  dialog[popover] {
    max-width: 70%;
    background-color: #f3f3f3;
    color: #322e2b;
    padding: 2em;
    border-radius: 30px;
    border: none;
    max-height: 80vh;
    overflow-y: auto;
    transition:
      display 0.3s allow-discrete,
      overlay 0.3s allow-discrete,
      opacity 0.3s,
      transform 0.3s;

    opacity: 1;
    transform: translateY(0);
  }

  dialog[popover]:not(:popover-open) {
    opacity: 0;
    transform: translateY(20px);
  }

  @starting-style {
    dialog[popover]:popover-open {
      opacity: 0;
      transform: translateY(20px);
    }
  }

  dialog[popover]::backdrop {
    transition:
      display 0.3s allow-discrete,
      overlay 0.3s allow-discrete,
      opacity 0.3s;
    opacity: 1;
  }

  @starting-style {
    dialog[popover]::backdrop {
      opacity: 0;
    }
  }

  .luk-knap {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #322e2b;
    line-height: 1;
  }

  .luk-knap:hover {
    color: #000;
  }
</style>
