---
const { logo, facebook, instagram, tiktok, mail, phone } = Astro.props;
---

<div class="grid_1-1-1">
    <div>
<h4>Kontakt os</h4>
<p>{phone}</p>
<p>{mail}</p>
</div>

<div class="some">
    <img src={facebook} alt="">
    <img src={instagram} alt="">
    <img src={tiktok} alt="">
    
</div>
<div class="logo">
<img src={logo} alt="">
</div>
</div>

<style>

.grid_1-1-1{
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    margin-bottom: 5em;
    background-color: #F3F3F3;
    padding: 2em;
    border-radius: 30px;
}

.some{
    text-align: end;
    margin-top: 4em;
}

.logo{
    text-align: end;
}

</style>