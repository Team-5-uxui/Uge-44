---
import Knapper from "./Knapper.astro";
const { title, img, variant, text, showButton, buttonText, buttonVariant, place, lost, dialogId, city, date, href } = Astro.props;
---

<div class={variant} data-city={city} data-date={date}>
  <img src={img} alt={title} />

  <div>
    <h2>{title}</h2>
    <p>{text}</p>
    <p>{lost}</p>
    <p>{place}</p>

    {
      showButton &&
        (href ? (
          <a href={href} target="_blank">
            <Knapper text={buttonText} variant={buttonVariant} />
          </a>
        ) : (
          <Knapper text={buttonText} variant={buttonVariant} popovertarget={dialogId} />
        ))
    }
    <slot />
  </div>
</div>

<style>
  .card-kategori {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2em;
    border: none;
    padding: 0.5em 2em;
    border-radius: 30px;
    background-color: var(--primary-btn);
    color: white;
    width: 100%;
    align-items: center;
    cursor: pointer;
    box-shadow: 6px 6px 4px rgba(0, 0, 0, 0.2);
  }

  .card-kategori img {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>

<style>
  .card-stotteven {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-align: center;
    margin: 2em 2em 5em 2em;
  }

  .card-stotteven p {
    max-width: 70%;
    place-self: center;
  }

  .card-stotteven img {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>

<style>
  .card-event {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 70%;
    margin: 4em;
    gap: 2em;
  }

  .card-event h2 {
    padding: 0.5rem 2rem;
    border: none;
    border-radius: 30px;
    background-color: var(--primary-btn);
    color: var(--text-inverted);
    cursor: pointer;
    max-width: fit-content;
    text-align: center;
  }

  .card-event-vertikal {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1em;
  }

  .card-event-vertikal img {
    width: 300px;
    height: auto;
    object-fit: cover;
    border-radius: 50%;
  }

  .card-event-vertikal h2 {
    padding: 0.5rem 2rem;
    border: none;
    border-radius: 30px;
    background-color: var(--primary-btn);
    color: var(--text-inverted);
    cursor: pointer;
  }
</style>

<style>
  .card-personer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 70%;
    margin: 4em;
  }

  .card-personer h2 {
    padding: 0.5rem 2rem;
    border: none;
    border-radius: 30px;
    margin-top: 2em;
    background-color: var(--primary-btn);
    color: var(--text-inverted);
    cursor: pointer;
    max-width: fit-content;
    text-align: center;
  }

  @media (max-width: 800px) {
    .card-kategori {
      gap: 1em;
      padding: 0.25em 1.5em;
      width: 100%;
    }

    .card-kategori img {
      width: 70px;
      height: 70px;
      object-fit: cover;
    }

    .card-kategori h2 {
      font-size: 1.1rem;
    }

    .card-event-vertikal img {
      width: 200px;
      height: 200px;
    }

    .card-stotteven {
      grid-template-columns: 1fr;
      margin: 1em;
    }

    .card-stotteven p {
      max-width: 100%;
      margin: 0 4em;
    }

    .card-stotteven img {
      margin: 0 auto;
    }

    .card-event {
      grid-template-columns: 1fr;
      max-width: 100%;
      margin: 2em 1em;
      text-align: center;
      justify-items: center;
    }

    .card-event h2 {
      width: fit-content;
      margin: 1em auto;
    }

    .card-personer {
      grid-template-columns: 1fr;
      max-width: 100%;
      margin: 1em;
      text-align: center;
      justify-items: center;
    }

    .card-personer h2 {
      width: fit-content;
      margin: 1em auto;
    }
  }
</style>
