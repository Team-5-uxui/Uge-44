import PersonerPopover from "../components/PersonerPopover.astro";
import EventPopover from "../components/EventPopover.astro";

const options = {
  headers: {
    apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImF1ZHJma2FmYnpmb2NtdXNpdGFhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyOTE4NjcsImV4cCI6MjA5MTg2Nzg2N30.A8wujbOYCH_6ffrOhON39YeOmKa2s8US46vDm6J06kU",
  },
};
const url = "https://audrfkafbzfocmusitaa.supabase.co/rest/v1/Personer";

const response = await fetch(url, options);
const data = await response.json();

const personer = data.filter((p) => p.name);
const events = data.filter((e) => e.eventnavn);
---

<PageLayout>
  {
    events.map((event) => (
      <>
        <Cards title={event.eventnavn} text={`Dato: ${event.date}`} place={`Sted: ${event.place}`} img={event.photo} variant="card-event" showButton={true} buttonText="Læs mere" buttonVariant="btn-primær" dialogId={`dialog-${event.id}`} />
        <EventPopover id={`dialog-${event.id}`} eventnavn={event.eventnavn} text={`Dato: ${event.date}`} place={`Sted: ${event.place}`} img={event.photo} about={event.about} buttonText="Tilmeld" buttonVariant="btn-tilmeld" />
      </>
    ))
  }
</PageLayout>
